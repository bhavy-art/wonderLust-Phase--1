<% layout("/layouts/boilerplate") %> 
<%= success %>

<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter{
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
    }

    .filter:hover{
        opacity: 1;
        cursor: pointer;
        color: black;
    }

    .tax-info{
        display: none;
    }

    .tax-toggle{
        border: 1px solid gray;
        border-radius: 10px;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 3rem;
        display: flex;
        align-items: center;
    }
</style>


<body>
    <!-- <h3>All Listings</h3> -->
